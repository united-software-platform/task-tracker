{
    "name": "req-control/app",
    "description": "Requirements Control Platform",
    "type": "project",
    "require": {
        "php": "^8.4",
        "mcp/sdk": "^0.4.0",
        "symfony/console": "^7.0",
        "symfony/dotenv": "^7.0",
        "symfony/framework-bundle": "^7.0",
        "symfony/yaml": "^7.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.70",
        "phpunit/phpunit": "^12.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint": "php-cs-fixer fix --dry-run --diff",
        "lint:fix": "php-cs-fixer fix",
        "analyse": "phpstan analyse",
        "test": "phpunit",
        "test:unit": "phpunit --testsuite Unit"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    }
}
